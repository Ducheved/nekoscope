{
  "name": "nekoscope",
  "version": "0.1.0",
  "description": "A tiny kawaii knowledge lens for Markdown-heavy repos.",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "tauri:dev": "tauri dev",
    "build": "vite build",
    "tauri:build": "tauri build",
    "lint": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm test && pnpm build && cargo fmt --check --manifest-path src-tauri/Cargo.toml && cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings && cargo test --manifest-path src-tauri/Cargo.toml",
    "release:local": "pnpm verify && pnpm tauri:build",
    "tauri": "tauri",
    "preview": "vite preview"
  },
  "license": "MPL-2.0",
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "jsonc-parser": "^3.3.1",
    "@lucide/svelte": "^1.18.0",
    "mermaid": "^11.4.1",
    "rehype-katex": "^7.0.1",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.1",
    "smol-toml": "^1.3.4",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.2",
    "typescript": "~5.6.2",
    "vitest": "^2.1.8",
    "vite": "^6.0.3",
    "@tauri-apps/cli": "^2"
  }
}
